[
    {
        "id":  "kp_ga_wo_001",
        "type":  "grammar",
        "title":  "が / を：誰做動作，誰被作用",
        "short_name":  "が vs を",
        "level":  "N5",
        "category":  "助詞",
        "memory_hook":  "が 是主角光環，を 是箭靶貼紙。動作從 が 發出，射中 を。",
        "core_explanation":  "が 標記動作的發起者（主語），を 標記動作作用的對象（受語）。例：猫が魚を食べる（貓吃魚）— 貓是主角，魚是箭靶。換成「魚が猫を食べる」意思完全反轉，要特別小心。",
        "examples":  [
                         {
                             "jp":  "猫が魚を食べる",
                             "zh":  "貓吃魚",
                             "note":  "猫=動作者(が)，魚=被作用(を)"
                         },
                         {
                             "jp":  "私が宿題をする",
                             "zh":  "我做作業",
                             "note":  "我=動作者，宿題=對象"
                         },
                         {
                             "jp":  "犬がボールを追いかける",
                             "zh":  "狗追球",
                             "note":  "主動追的是狗"
                         }
                     ],
        "weakness_tags":  [
                              "が_vs_を",
                              "主詞_vs_受詞",
                              "主動_vs_被動"
                          ],
        "related_question_ids":  [
                                     "Q_GRAMMAR_CAT_001",
                                     "Q_GRAMMAR_CAT_002",
                                     "Q_GRAMMAR_MOTHER_001"
                                 ]
    },
    {
        "id":  "kp_ni_de_e_001",
        "type":  "grammar",
        "title":  "に / で / へ：目的地、場所、方向",
        "short_name":  "に vs で vs へ",
        "level":  "N5",
        "category":  "助詞",
        "memory_hook":  "に 是「到達點」（目的地釘子），で 是「舞台」（動作發生的場所），へ 是「箭頭方向」（往那邊走）。",
        "core_explanation":  "に 表示移動的目標或到達點（学校に行く）；で 表示動作發生的場所或使用的手段（図書館で勉強する）；へ 表示方向，語感比に更強調「朝那個方向移動」。",
        "examples":  [
                         {
                             "jp":  "学校に行く",
                             "zh":  "去學校（到達目的地）",
                             "note":  "に=到達點"
                         },
                         {
                             "jp":  "図書館で本を読む",
                             "zh":  "在圖書館讀書",
                             "note":  "で=動作場所"
                         },
                         {
                             "jp":  "東京へ向かう",
                             "zh":  "往東京去",
                             "note":  "へ=方向感更強"
                         }
                     ],
        "weakness_tags":  [
                              "に_vs_で",
                              "へ_vs_に",
                              "移動目的地"
                          ],
        "related_question_ids":  [
                                     "Q_PARTICLE_MOVE_001",
                                     "Q_PARTICLE_MOVE_002",
                                     "Q_PARTICLE_MOVE_005"
                                 ]
    },
    {
        "id":  "kp_passive_001",
        "type":  "grammar",
        "title":  "被動句：BはAにVられる",
        "short_name":  "被動形",
        "level":  "N4",
        "category":  "動詞活用",
        "memory_hook":  "被動句：受難的主角放前面（は），加害者用に，動詞加「られる」。記口訣：「我被貓咬」→ 私は猫に噛まれた。",
        "core_explanation":  "日語被動句結構：受動者は＋施動者に＋動詞られる形。被動形變化：一段動詞去る加られる，五段動詞未然形加れる，する→される，くる→こられる。被動句暗示「受到影響、受難感」。",
        "examples":  [
                         {
                             "jp":  "私は先生に叱られた",
                             "zh":  "我被老師罵了",
                             "note":  "受難感，私が主角"
                         },
                         {
                             "jp":  "財布を盗まれた",
                             "zh":  "錢包被偷了",
                             "note":  "財布受到影響"
                         },
                         {
                             "jp":  "雨に降られた",
                             "zh":  "被雨淋了",
                             "note":  "間接被動，非人物施動"
                         }
                     ],
        "weakness_tags":  [
                              "被動_vs_使役",
                              "が_vs_を",
                              "主動_vs_被動"
                          ],
        "related_question_ids":  [
                                     "Q_GRAMMAR_CAT_005",
                                     "Q_GRAMMAR_CAT_006",
                                     "Q_GRAMMAR_MOTHER_005"
                                 ]
    },
    {
        "id":  "kp_causative_001",
        "type":  "grammar",
        "title":  "使役句：AがBにVさせる",
        "short_name":  "使役形",
        "level":  "N4",
        "category":  "動詞活用",
        "memory_hook":  "使役：老闆(が)叫員工(に)做事(させる)。記口訣：「讓／叫／命令」→ させる家族。",
        "core_explanation":  "使役句表示A讓B做某事，或強迫B做。結構：使役者が＋被使役者に＋動詞させる形。被使役者有時用を（表強迫）。使役形：一段去る加させる，五段未然形加せる，する→させる。",
        "examples":  [
                         {
                             "jp":  "先生が生徒に本を読ませる",
                             "zh":  "老師讓學生讀書",
                             "note":  "先生=使役者，生徒=被使役者"
                         },
                         {
                             "jp":  "母は子供を寝させた",
                             "zh":  "媽媽讓孩子去睡覺",
                             "note":  "を表示有點強制的語感"
                         },
                         {
                             "jp":  "ちょっと考えさせてください",
                             "zh":  "讓我想一下",
                             "note":  "請求讓我做的禮貌用法"
                         }
                     ],
        "weakness_tags":  [
                              "使役_vs_被動",
                              "が_vs_に",
                              "主動_vs_被動"
                          ],
        "related_question_ids":  [
                                     "Q_GRAMMAR_CAT_007",
                                     "Q_GRAMMAR_MOTHER_007"
                                 ]
    },
    {
        "id":  "kp_tsuku_001",
        "type":  "grammar",
        "title":  "つく / つける / ついている / つけてある",
        "short_name":  "つく系列",
        "level":  "N5",
        "category":  "自他動詞 / ている / てある",
        "memory_hook":  "燈的一生：つく（亮起來）→ つける（你打開它）→ ついている（現在亮著）→ つけてある（有人幫你開好了）。",
        "core_explanation":  "つく（自動詞）：燈自己亮起來，狀態變化。つける（他動詞）：人主動打開燈。ついている（自動詞+ている）：目前保持亮的狀態。つけてある（他動詞+てある）：有人事先打開，結果留著給你。",
        "examples":  [
                         {
                             "jp":  "電気がつく",
                             "zh":  "燈亮起來",
                             "note":  "狀態變化，自動詞"
                         },
                         {
                             "jp":  "電気をつける",
                             "zh":  "把燈打開",
                             "note":  "人主動操作，他動詞"
                         },
                         {
                             "jp":  "電気がついている",
                             "zh":  "燈亮著",
                             "note":  "持續狀態，ている"
                         },
                         {
                             "jp":  "電気がつけてある",
                             "zh":  "燈已被打開好了",
                             "note":  "事先準備，てある"
                         }
                     ],
        "weakness_tags":  [
                              "つく_vs_つける",
                              "ている_vs_てある",
                              "自動詞_vs_他動詞",
                              "狀態變化_vs_持續狀態"
                          ],
        "related_question_ids":  [
                                     "Q_TSUKU_001",
                                     "Q_TSUKU_003",
                                     "Q_TSUKU_006",
                                     "Q_TSUKU_009"
                                 ]
    },
    {
        "id":  "kp_aku_001",
        "type":  "grammar",
        "title":  "開く / 開ける / 開いている / 開けてある",
        "short_name":  "開く系列",
        "level":  "N5",
        "category":  "自他動詞 / ている / てある",
        "memory_hook":  "門的一生：開く（自己開了）→ 開ける（你開它）→ 開いている（現在開著）→ 開けてある（有人幫你開好了）。",
        "core_explanation":  "開く（自動詞）：門自己打開，狀態變化。開ける（他動詞）：人主動打開門。開いている（自動詞+ている）：目前保持開的狀態。開けてある（他動詞+てある）：有人事先把門打開，結果留著。",
        "examples":  [
                         {
                             "jp":  "ドアが開く",
                             "zh":  "門開了",
                             "note":  "門自己打開"
                         },
                         {
                             "jp":  "ドアを開ける",
                             "zh":  "把門打開",
                             "note":  "人的動作"
                         },
                         {
                             "jp":  "ドアが開いている",
                             "zh":  "門開著",
                             "note":  "現在的狀態"
                         },
                         {
                             "jp":  "ドアが開けてある",
                             "zh":  "門已被打開好了",
                             "note":  "有人準備好的"
                         }
                     ],
        "weakness_tags":  [
                              "開く_vs_開ける",
                              "ている_vs_てある",
                              "自動詞_vs_他動詞"
                          ],
        "related_question_ids":  [
                                     "Q_AKU_001",
                                     "Q_AKU_003",
                                     "Q_AKU_006",
                                     "Q_AKU_009"
                                 ]
    },
    {
        "id":  "kp_hairu_001",
        "type":  "grammar",
        "title":  "入る / 入れる / 入っている / 入れてある",
        "short_name":  "入る系列",
        "level":  "N5",
        "category":  "自他動詞 / ている / てある",
        "memory_hook":  "資料的命運：入る（自己進去）→ 入れる（你放進去）→ 入っている（現在在裡面）→ 入れてある（有人幫你放好了）。",
        "core_explanation":  "入る（自動詞）：東西進入某地，狀態變化。入れる（他動詞）：人主動把東西放進去。入っている（自動詞+ている）：目前在裡面的狀態。入れてある（他動詞+てある）：有人事先放進去，結果留著。",
        "examples":  [
                         {
                             "jp":  "箱に資料が入る",
                             "zh":  "資料進到箱子裡",
                             "note":  "自動進入"
                         },
                         {
                             "jp":  "箱に資料を入れる",
                             "zh":  "把資料放進箱子裡",
                             "note":  "人放進去"
                         },
                         {
                             "jp":  "箱に資料が入っている",
                             "zh":  "資料在箱子裡",
                             "note":  "現在的狀態"
                         },
                         {
                             "jp":  "箱に資料が入れてある",
                             "zh":  "資料已被放進去了",
                             "note":  "事先準備好"
                         }
                     ],
        "weakness_tags":  [
                              "入る_vs_入れる",
                              "ている_vs_てある",
                              "自動詞_vs_他動詞"
                          ],
        "related_question_ids":  [
                                     "Q_HAIRU_001",
                                     "Q_HAIRU_003",
                                     "Q_HAIRU_006",
                                     "Q_HAIRU_009"
                                 ]
    },
    {
        "id":  "kp_deru_001",
        "type":  "grammar",
        "title":  "出る / 出す / 出ている / 出してある",
        "short_name":  "出る系列",
        "level":  "N5",
        "category":  "自他動詞 / ている / てある",
        "memory_hook":  "文件的旅程：出る（自己出來）→ 出す（你拿出來）→ 出ている（現在在外面）→ 出してある（有人幫你準備好放外面）。",
        "core_explanation":  "出る（自動詞）：東西自己出現或離開。出す（他動詞）：人主動把東西拿出或提交。出ている（自動詞+ている）：目前已出現在外的狀態。出してある（他動詞+てある）：有人事先把東西拿出放好。",
        "examples":  [
                         {
                             "jp":  "書類が出る",
                             "zh":  "文件出來",
                             "note":  "自動出現"
                         },
                         {
                             "jp":  "書類を出す",
                             "zh":  "拿出文件",
                             "note":  "人主動提交"
                         },
                         {
                             "jp":  "書類が出ている",
                             "zh":  "文件已出來放著",
                             "note":  "目前狀態"
                         },
                         {
                             "jp":  "書類が出してある",
                             "zh":  "文件已被拿出放好了",
                             "note":  "事先準備"
                         }
                     ],
        "weakness_tags":  [
                              "出る_vs_出す",
                              "ている_vs_てある",
                              "自動詞_vs_他動詞"
                          ],
        "related_question_ids":  [
                                     "Q_DERU_001",
                                     "Q_DERU_003",
                                     "Q_DERU_006",
                                     "Q_DERU_008"
                                 ]
    },
    {
        "id":  "kp_miru_001",
        "type":  "grammar",
        "title":  "見る / 見える / 見せる / 見られる",
        "short_name":  "見る系列",
        "level":  "N5",
        "category":  "知覺動詞",
        "memory_hook":  "見：見る（主動看）vs 見える（自然看得見，不是你選的）。見せる（展示給人看）。見られる（可以看/被看）。",
        "core_explanation":  "見る：主動、有意識地用眼睛看。見える：眼睛不需主動努力就自然進入視野。見せる：使役，讓別人看，展示。見られる：可能形「能看到」或被動「被看見」。",
        "examples":  [
                         {
                             "jp":  "富士山を見る",
                             "zh":  "看富士山",
                             "note":  "主動凝視"
                         },
                         {
                             "jp":  "富士山が見える",
                             "zh":  "看得見富士山",
                             "note":  "自然進入視野"
                         },
                         {
                             "jp":  "写真を見せる",
                             "zh":  "給別人看照片",
                             "note":  "展示行為"
                         },
                         {
                             "jp":  "この映画が見られる",
                             "zh":  "可以看這部電影",
                             "note":  "可能形"
                         }
                     ],
        "weakness_tags":  [
                              "見る_vs_見える",
                              "見せる_vs_見る",
                              "可能形",
                              "知覺動詞"
                          ],
        "related_question_ids":  [
                                     "Q_MIRU_001",
                                     "Q_MIRU_003",
                                     "Q_MIRU_006",
                                     "Q_MIRU_009"
                                 ]
    },
    {
        "id":  "kp_kiku_001",
        "type":  "grammar",
        "title":  "聞く / 聞こえる / 聞かせる / 聞ける",
        "short_name":  "聞く系列",
        "level":  "N5",
        "category":  "知覺動詞",
        "memory_hook":  "聽：聞く（主動聽）vs 聞こえる（聲音自動飛進耳朵）。聞かせる（播給別人聽）。聞ける（有機會聽）。",
        "core_explanation":  "聞く：主動、有意識地去聽。聞こえる：聲音自然傳入耳朵，不需主動。聞かせる：使役，讓別人聽，播放。聞ける：可能形「能聽到、有機會聽」。",
        "examples":  [
                         {
                             "jp":  "音楽を聞く",
                             "zh":  "聽音樂",
                             "note":  "主動聆聽"
                         },
                         {
                             "jp":  "音楽が聞こえる",
                             "zh":  "聽得到音樂",
                             "note":  "聲音自然入耳"
                         },
                         {
                             "jp":  "音楽を聞かせる",
                             "zh":  "播音樂給別人聽",
                             "note":  "使別人聽"
                         },
                         {
                             "jp":  "この曲が聞ける",
                             "zh":  "可以聽這首歌",
                             "note":  "有條件/機會"
                         }
                     ],
        "weakness_tags":  [
                              "聞く_vs_聞こえる",
                              "聞かせる_vs_聞く",
                              "可能形",
                              "知覺動詞"
                          ],
        "related_question_ids":  [
                                     "Q_KIKU_001",
                                     "Q_KIKU_003",
                                     "Q_KIKU_006",
                                     "Q_KIKU_009"
                                 ]
    },
    {
        "id":  "kp_wa_ga_001",
        "type":  "grammar",
        "title":  "は / が：話題與焦點",
        "short_name":  "は vs が",
        "level":  "N5",
        "category":  "助詞",
        "memory_hook":  "は像把話題放到桌上；が像手電筒照出答案。",
        "core_explanation":  "は用來提示已知話題或對比，が用來標出新資訊、主語或回答「誰、什麼」的焦點。",
        "examples":  [
                         {
                             "jp":  "私は学生です。",
                             "zh":  "我是學生。",
                             "note":  "說明關於我的身份。"
                         },
                         {
                             "jp":  "誰が来ますか。田中さんが来ます。",
                             "zh":  "誰要來？田中先生要來。",
                             "note":  "が回答未知焦點。"
                         },
                         {
                             "jp":  "コーヒーは飲みますが、牛乳は飲みません。",
                             "zh":  "咖啡我喝，但牛奶不喝。",
                             "note":  "は可形成對比。"
                         }
                     ],
        "weakness_tags":  [
                              "は_vs_が",
                              "話題_vs_焦點",
                              "主語辨識"
                          ],
        "related_question_ids":  [

                                 ]
    },
    {
        "id":  "kp_no_001",
        "type":  "grammar",
        "title":  "の：所屬、內容、連體修飾",
        "short_name":  "の",
        "level":  "N5",
        "category":  "助詞",
        "memory_hook":  "の像膠水，把兩個名詞黏起來。",
        "core_explanation":  "の可以表示所屬、種類、內容、位置關係，也可讓前面的名詞修飾後面的名詞。",
        "examples":  [
