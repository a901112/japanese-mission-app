    {
        "id":  "kp_request_001",
        "type":  "grammar",
        "title":  "ください / ませんか：請求與邀請",
        "short_name":  "請求",
        "level":  "N5",
        "category":  "句型",
        "memory_hook":  "ください是請對方做；ませんか是柔和邀請。",
        "core_explanation":  "てください表示請求對方做某動作；ませんか可用於邀請或委婉詢問，比命令式柔和。",
        "examples":  [
