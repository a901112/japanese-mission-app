                         {
                             "jp":  "机の上に本があります。",
                             "zh":  "桌上有書。",
                             "note":  "物品用ある。"
                         },
                         {
                             "jp":  "公園に木があります。",
                             "zh":  "公園裡有樹。",
                             "note":  "植物通常用ある。"
                         }
