                             "note":  "請求。"
                         },
                         {
                             "jp":  "一緒に行きませんか。",
                             "zh":  "要不要一起去？",
                             "note":  "邀請。"
                         },
                         {
                             "jp":  "もう一度言ってください。",
                             "zh":  "請再說一次。",
                             "note":  "要求重複。"
                         }
                     ],
        "weakness_tags":  [
                              "てください",
                              "ませんか",
                              "請求_vs_邀請"
                          ],
