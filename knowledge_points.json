    {
        "id":  "kp_mo_001",
        "type":  "grammar",
        "title":  "も：也、都、連...也",
        "short_name":  "も",
        "level":  "N5",
        "category":  "助詞",
        "memory_hook":  "も會把句子接到前面的同類資訊。",
        "core_explanation":  "も表示「也」或「同樣」，否定句中可形成「都不」。數量詞後也能表示驚訝的多或少。",
        "examples":  [
                         {
                             "jp":  "私も行きます。",
                             "zh":  "我也去。",
                             "note":  "同樣參與。"
                         },
                         {
                             "jp":  "何も食べませんでした。",
                             "zh":  "什麼都沒吃。",
                             "note":  "疑問詞加も加否定。"
                         },
                         {
                             "jp":  "三時間も待ちました。",
                             "zh":  "竟然等了三小時。",
                             "note":  "帶驚訝感。"
                         }
                     ],
        "weakness_tags":  [
                              "も",
                              "否定搭配",
                              "同類追加"
                          ],
        "related_question_ids":  [

                                 ]
    },
    {
        "id":  "kp_kara_made_001",
        "type":  "grammar",
        "title":  "から / まで：起點與終點",
        "short_name":  "から/まで",
        "level":  "N5",
        "category":  "助詞",
        "memory_hook":  "から是起跑線，まで是終點線。",
        "core_explanation":  "から表示時間、地點或理由的起點；まで表示範圍終點。兩者常一起使用，但也可以單獨出現。",
        "examples":  [
                         {
                             "jp":  "九時から五時まで働きます。",
                             "zh":  "從九點工作到五點。",
