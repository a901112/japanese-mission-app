    {
        "id":  "kp_adjective_001",
        "type":  "grammar",
        "title":  "い形容詞 / な形容詞：接名詞與變化",
        "short_name":  "い形/な形",
        "level":  "N5",
        "category":  "形容詞",
        "memory_hook":  "い形容詞自己帶い；な形容詞接名詞前要借な。",
        "core_explanation":  "い形容詞可直接修飾名詞；な形容詞接名詞時要加な。否定與過去變化也不同。",
        "examples":  [
                         {
                             "jp":  "おいしい料理です。",
                             "zh":  "好吃的料理。",
                             "note":  "い形容詞直接接名詞。"
                         },
                         {
                             "jp":  "静かな部屋です。",
                             "zh":  "安靜的房間。",
                             "note":  "な形容詞接名詞加な。"
                         },
                         {
                             "jp":  "この店は有名です。",
                             "zh":  "這家店很有名。",
                             "note":  "句尾不用な。"
                         }
                     ],
        "weakness_tags":  [
                              "い形容詞_vs_な形容詞",
                              "連體修飾",
                              "形容詞變化"
                          ],
        "related_question_ids":  [

                                 ]
    },
    {
