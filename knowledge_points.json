    {
        "id":  "kp_past_negative_001",
        "type":  "grammar",
        "title":  "過去與否定：です / ます 的基本變化",
        "short_name":  "過去否定",
        "level":  "N5",
        "category":  "句尾變化",
        "memory_hook":  "先決定是不是過去，再決定是不是否定。",
        "core_explanation":  "名詞與な形容詞常用です系統；動詞用ます系統。過去、否定、過去否定各有固定形式。",
        "examples":  [
                         {
                             "jp":  "学生ではありません。",
                             "zh":  "不是學生。",
                             "note":  "名詞否定。"
                         },
                         {
                             "jp":  "昨日行きませんでした。",
                             "zh":  "昨天沒去。",
                             "note":  "動詞過去否定。"
                         },
                         {
                             "jp":  "この店は高くなかったです。",
                             "zh":  "這家店不貴。",
                             "note":  "い形容詞過去否定。"
                         }
                     ],
