                         {
                             "jp":  "少し待ってください。",
                             "zh":  "請稍等。",
                             "note":  "請求。"
                         },
                         {
                             "jp":  "窓が開いています。",
                             "zh":  "窗戶開著。",
                             "note":  "結果狀態。"
                         }
