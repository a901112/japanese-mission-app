                             "note":  "自己的願望。"
                         },
                         {
                             "jp":  "日本へ行きたいです。",
                             "zh":  "想去日本。",
                             "note":  "動詞ます形去ます加たい。"
                         },
                         {
                             "jp":  "何を食べたいですか。",
                             "zh":  "你想吃什麼？",
                             "note":  "詢問對方願望。"
                         }
                     ],
        "weakness_tags":  [
                              "たい",
                              "願望",
                              "ます形"
